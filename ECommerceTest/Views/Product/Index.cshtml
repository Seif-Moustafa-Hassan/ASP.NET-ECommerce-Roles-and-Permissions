@model IEnumerable<ECommerceTest.Models.Product>
@using ECommerceTest.Helpers

@using ECommerceTest.Helpers

@{
    ViewBag.Title = "Products";
}

<h2>Products</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        @TempData["SuccessMessage"]
    </div>
}

<p>
    @if (PermissionHelper.HasPermission("Create"))
    {
        @Html.ActionLink("Create New Product", "Create", null, new { @class = "btn btn-success" })
    }
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>@(item.Status ? "Active" : "Inactive")</td>
                <td>
                    @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-info btn-sm" })

                    @if (PermissionHelper.HasPermission("AddToCart"))
                    {
                        @Html.ActionLink("Add To Cart", "Add", "Cart", new { productId = item.Id }, new { @class = "btn btn-warning btn-sm" })
                    }

                    @if (PermissionHelper.HasPermission("Update"))
                    {
                        @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-primary btn-sm" })
                    }

                    @if (PermissionHelper.HasPermission("Delete"))
                    {
                        @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                    }
                </td>
            </tr>
        }
    </tbody>
</table>